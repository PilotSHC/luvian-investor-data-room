# Investor data-room password gate.
# Copy to .env.local for local dev. Set the same vars in Vercel dashboard
# (Settings → Environment Variables) for production.

# Single shared password — anything you like. Long. Don't reuse.
# Example: a passphrase like "neon-quartz-bicycle-77".
INVESTOR_ROOM_PASSWORD=change-me-to-a-long-random-passphrase

# HMAC secret used to sign the auth cookie. 32+ chars random. Treat as a secret.
# Generate one with:  openssl rand -hex 32
INVESTOR_ROOM_COOKIE_SECRET=replace-with-32-bytes-of-random-hex

# Cookie lifetime in seconds (default = 7 days = 604800).
INVESTOR_ROOM_COOKIE_TTL=604800
