---
import DataRoomLayout from '@/layouts/DataRoomLayout.astro';
import { SECTIONS } from '@/data/sections';
---

<DataRoomLayout title="Luvian Labs LLC · Investor Data Room">
  <section class="mb-10">
    <p class="text-xs uppercase tracking-widest text-ink-500">Pre-Seed · Confidential · Click-through Acknowledgment</p>
    <h1 class="mt-2 text-4xl font-bold leading-tight text-ink-900 sm:text-5xl">
      The operational context layer for engineering organisations.
    </h1>
    <p class="mt-4 max-w-3xl text-lg text-ink-700">
      Foundation models have commoditised. Enterprise AI value now accrues to the
      <strong class="text-ink-900">operational substrate</strong> the model reasons over —
      proprietary context, ontology, provenance, governed retrieval. Luvian is building that
      substrate, starting with the engineering organisations where the cost of hallucination
      is highest. This room is the early infrastructure brief for that thesis.
    </p>

    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card">
        <div class="text-xs uppercase tracking-wide text-ink-500">Entity</div>
        <div class="mt-1 font-semibold text-ink-900">Luvian Labs LLC</div>
        <div class="mt-1 text-xs text-ink-500">Delaware single-member LLC · Sole member: Stephan Claxton</div>
      </div>
      <div class="card">
        <div class="text-xs uppercase tracking-wide text-ink-500">Round</div>
        <div class="mt-1 font-semibold text-ink-900">$1.5M – $2.0M</div>
        <div class="mt-1 text-xs text-ink-500">Convertible Note · Auto-converts on Qualified Financing or Delaware&nbsp;Flip</div>
      </div>
      <div class="card">
        <div class="text-xs uppercase tracking-wide text-ink-500">Contact</div>
        <div class="mt-1 font-semibold text-ink-900">stephan@luvian.info</div>
        <div class="mt-1 text-xs text-ink-500">Founder &amp; sole member</div>
      </div>
    </div>
  </section>

  <section class="mb-10 rounded-lg border-l-4 border-accent bg-accent/5 p-5 text-sm text-ink-800">
    <strong class="text-ink-900">If you have 30 minutes, read in this order:</strong>
    <ol class="mt-3 list-decimal space-y-2 pl-5">
      <li>
        <a class="text-accent-dark underline" href="/04-technical-architecture/architecture-vision-memo">
          Architecture Vision Memo
        </a> — the centrepiece thesis document.
      </li>
      <li>
        <a class="text-accent-dark underline" href="/05-market-thesis/why-now-memo">
          Why Now Memo
        </a> — the macro narrative.
      </li>
      <li>
        <a class="text-accent-dark underline" href="/03-product-demo/demo-walkthrough">
          Demo Walkthrough
        </a> — watch the confidential video.
      </li>
      <li>
        <a class="text-accent-dark underline" href="/10-appendix/investor-qa">
          Investor Q&amp;A
        </a> — answers to the questions you're already drafting.
      </li>
    </ol>
  </section>

  <section class="mb-10 rounded-lg border-l-4 border-warn bg-warn/5 p-5 text-sm text-ink-800">
    <strong class="text-warn">Confidential.</strong>
    All materials in this room are subject to the
    <a class="text-accent-dark underline" href="/agreement">click-through confidentiality &amp; privacy acknowledgment</a>
    you accepted at sign-in. Do not redistribute.
    Any document marked <span class="font-mono">⏳ POST-FLIP</span> becomes operative after the
    planned LLC → Delaware C-corp Reorganization; it is provided so counsel and incoming investors have
    the full picture. The <em>active</em> funding instrument is the
    <a class="text-accent-dark underline" href="/10-appendix/convertible-note-template">Convertible Promissory Note</a>.
  </section>

  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-ink-500">Sections</h2>
    <div class="mt-3 grid gap-4 sm:grid-cols-2">
      {SECTIONS.map((section) => (
        <a href={section.href} class="card-hover group">
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-sm text-ink-500">{section.number}</span>
            <h3 class="text-lg font-semibold text-ink-900 group-hover:text-accent-dark">{section.title}</h3>
          </div>
          <p class="mt-2 text-sm text-ink-700">{section.description}</p>
          <p class="mt-3 text-xs text-ink-500">{section.files.length} documents →</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-ink-500">Quick Downloads</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a class="btn-ghost" href="/pdf/Pitch_Deck_2026_05.pdf">Pitch Deck (PDF)</a>
      <a class="btn-ghost" href="/csv/Financial_Model_2026_05.csv">Financial Model (CSV)</a>
      <a class="btn-ghost" href="/csv/Capitalization_Table_2026_05.csv">Cap Table (CSV)</a>
    </div>
  </section>
</DataRoomLayout>
