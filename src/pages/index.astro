---
import DataRoomLayout from '@/layouts/DataRoomLayout.astro';
import { SECTIONS } from '@/data/sections';
---

<DataRoomLayout title="Luvian Labs LLC · Investor Data Room">
  <section class="mb-10">
    <p class="text-xs uppercase tracking-widest text-ink-300">Pre-Seed · Confidential · Click-through Acknowledgment</p>
    <h1 class="mt-2 text-4xl font-bold leading-tight text-ink-50 sm:text-5xl">
      Luvian Labs LLC
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-ink-200">
      The MBSE platform that systems engineers and software developers can finally agree on.
      Browser-native, AI-native, real-time collaborative, SysML&nbsp;v2-first.
    </p>

    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card">
        <div class="text-xs uppercase tracking-wide text-ink-300">Entity</div>
        <div class="mt-1 font-semibold text-ink-50">Luvian Labs LLC</div>
        <div class="mt-1 text-xs text-ink-300">Single-member LLC · Sole member: Stephan Claxton</div>
      </div>
      <div class="card">
        <div class="text-xs uppercase tracking-wide text-ink-300">Round</div>
        <div class="mt-1 font-semibold text-ink-50">$1.5M – $2.0M</div>
        <div class="mt-1 text-xs text-ink-300">Convertible Note · Auto-converts on Qualified Financing or Delaware&nbsp;Flip</div>
      </div>
      <div class="card">
        <div class="text-xs uppercase tracking-wide text-ink-300">Contact</div>
        <div class="mt-1 font-semibold text-ink-50">stephan@luvian.info</div>
        <div class="mt-1 text-xs text-ink-300">Founder & sole member</div>
      </div>
    </div>
  </section>

  <section class="mb-10 rounded-lg border-l-4 border-warn bg-warn/5 p-5 text-sm text-ink-100">
    <strong class="text-warn">Read first:</strong>
    All materials in this data room are confidential and provided subject to the
    <a class="underline" href="/agreement">click-through confidentiality &amp; privacy acknowledgment</a>
    you accepted at sign-in. Do not redistribute.
    Any document marked <span class="font-mono">⏳ POST-FLIP</span> applies after the planned LLC → Delaware C-corp Reorganization;
    it is provided so counsel and incoming investors have the full picture. The <em>active</em> instrument right now is the
    <a class="underline" href="/05-agreements-and-contracts/convertible-note-template">Convertible Promissory Note</a>.
  </section>

  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-ink-300">Sections</h2>
    <div class="mt-3 grid gap-4 sm:grid-cols-2">
      {SECTIONS.map((section) => (
        <a href={section.href} class="card-hover group">
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-sm text-ink-300">{section.number}</span>
            <h3 class="text-lg font-semibold text-ink-50 group-hover:text-white">{section.title}</h3>
          </div>
          <p class="mt-2 text-sm text-ink-200">{section.description}</p>
          <p class="mt-3 text-xs text-ink-400">{section.files.length} documents →</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-10">
    <h2 class="text-xs font-semibold uppercase tracking-widest text-ink-300">Quick Downloads</h2>
    <div class="mt-3 flex flex-wrap gap-3">
      <a class="btn-ghost" href="/pdf/Pitch_Deck_2026_05.pdf">Pitch Deck (PDF)</a>
      <a class="btn-ghost" href="/csv/Financial_Model_2026_05.csv">Financial Model (CSV)</a>
      <a class="btn-ghost" href="/csv/Capitalization_Table_2026_05.csv">Cap Table (CSV)</a>
      <a class="btn-ghost" href="/pdf/SAFE_Playbook_2026_05.pdf">SAFE Playbook (PDF)</a>
      <a class="btn-ghost" href="/pdf/Team_Plan_2026_05.pdf">Team Plan (PDF)</a>
      <a class="btn-ghost" href="/pdf/Company_Strategy_2026_05.pdf">Company Strategy (PDF)</a>
    </div>
  </section>
</DataRoomLayout>
