---
import DataRoomLayout from '@/layouts/DataRoomLayout.astro';
import { findSection } from '@/data/sections';

export const prerender = false;

const { section: sectionId } = Astro.params;
const section = findSection(sectionId ?? '');
if (!section) {
  return Astro.redirect('/', 302);
}
---

<DataRoomLayout
  title={`${section.number} · ${section.title}`}
  description={section.description}
  currentSection={section.id}
>
  <p class="text-xs uppercase tracking-widest text-ink-300">Section {section.number}</p>
  <h1 class="mt-2 text-3xl font-bold text-ink-50">{section.title}</h1>
  <p class="mt-3 text-ink-200">{section.description}</p>

  <ul class="mt-8 space-y-3">
    {section.files.map((file) => (
      <li>
        <a href={`${section.href}/${file.slug}`} class="card-hover block">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h2 class="text-base font-semibold text-ink-50">{file.title}</h2>
            <span class="text-xs text-ink-300">View →</span>
          </div>
          {file.blurb && <p class="mt-1 text-sm text-ink-200">{file.blurb}</p>}
          {file.download && (
            <div class="mt-2 flex flex-wrap gap-2">
              {file.download.map((dl) => (
                <span class="badge-info">{dl.label}</span>
              ))}
            </div>
          )}
        </a>
      </li>
    ))}
  </ul>
</DataRoomLayout>
