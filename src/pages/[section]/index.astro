---
import DataRoomLayout from '@/layouts/DataRoomLayout.astro';
import { findSection } from '@/data/sections';

export const prerender = false;

const { section: sectionId } = Astro.params;
const section = findSection(sectionId ?? '');
if (!section) {
  return Astro.redirect('/', 302);
}
---

<DataRoomLayout
  title={`${section.number} · ${section.title}`}
  description={section.description}
  currentSection={section.id}
>
  <nav class="mb-6 text-xs text-ink-500">
    <a href="/" class="hover:text-ink-900">Data Room</a>
    <span class="mx-2 text-ink-300">/</span>
    <span>{section.number} · {section.short}</span>
  </nav>

  <p class="text-xs uppercase tracking-widest text-ink-500">Section {section.number}</p>
  <h1 class="mt-2 text-3xl font-bold text-ink-900">{section.title}</h1>
  <p class="mt-3 max-w-3xl text-ink-700">{section.description}</p>

  <ul class="mt-8 space-y-3">
    {section.files.map((file) => {
      const isPrimary = file.emphasis === 'primary';
      return (
        <li>
          <a
            href={`${section.href}/${file.slug}`}
            class={
              isPrimary
                ? 'card-hover block border-l-4 border-accent bg-accent/5'
                : 'card-hover block'
            }
          >
            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h2 class={isPrimary ? 'text-base font-semibold text-accent-dark' : 'text-base font-semibold text-ink-900'}>
                {isPrimary && (
                  <span class="mr-2 inline-block rounded bg-accent/20 px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest text-accent-dark">
                    Read first
                  </span>
                )}
                {file.title}
              </h2>
              <span class="text-xs text-ink-500">View →</span>
            </div>
            {file.blurb && <p class="mt-1 text-sm text-ink-700">{file.blurb}</p>}
            {file.download && (
              <div class="mt-2 flex flex-wrap gap-2">
                {file.download.map((dl) => (
                  <span class="badge-info">{dl.label}</span>
                ))}
              </div>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</DataRoomLayout>
