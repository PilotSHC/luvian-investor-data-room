---
import { getEntry, render } from 'astro:content';
import DataRoomLayout from '@/layouts/DataRoomLayout.astro';
import { findFile } from '@/data/sections';

export const prerender = false;

const { section: sectionId, slug } = Astro.params;
const found = findFile(sectionId ?? '', slug ?? '');
if (!found) {
  return Astro.redirect('/', 302);
}
const { section, file } = found;
const entryId = `${section.id}--${file.slug}`;
const entry = await getEntry('dataroom', entryId);
let Content: any = null;
let fallback: string | null = null;
if (entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
} else {
  fallback = `<p><em>Content not yet synced.</em></p>`;
}
---

<DataRoomLayout
  title={`${section.number} · ${file.title}`}
  description={file.blurb}
  currentSection={section.id}
  currentSlug={file.slug}
>
  <nav class="mb-6 text-xs text-ink-500">
    <a href="/" class="hover:text-ink-900">Data Room</a>
    <span class="mx-2 text-ink-300">/</span>
    <a href={section.href} class="hover:text-ink-900">{section.number} · {section.short}</a>
  </nav>

  <header class="mb-6">
    <p class="text-xs uppercase tracking-widest text-ink-500">Section {section.number}</p>
    <h1 class="mt-1 text-2xl font-bold text-ink-900 sm:text-3xl">{file.title}</h1>
    {file.blurb && <p class="mt-2 max-w-3xl text-ink-700">{file.blurb}</p>}
  </header>

  {file.download && file.download.length > 0 && (
    <div class="mb-6 flex flex-wrap gap-2">
      {file.download.map((dl) => (
        <a class="btn-ghost" href={dl.href}>↓ {dl.label}</a>
      ))}
    </div>
  )}

  {file.embedHtml && (
    <div class="mb-8">
      <div
        class="overflow-hidden rounded-lg ring-1 ring-ink-200 bg-white shadow-sm"
        style="aspect-ratio: 16 / 10;"
      >
        <iframe
          src={file.embedHtml}
          title={file.title}
          class="h-full w-full"
          loading="lazy"
          allow="fullscreen"
          allowfullscreen
        ></iframe>
      </div>
      <p class="mt-2 text-xs text-ink-500">
        Live deck. Use the deck's own arrow keys or on-screen controls to advance slides. On mobile, tap to focus the deck before swiping.
      </p>
    </div>
  )}

  <article class="prose max-w-4xl">
    {Content ? <Content /> : <Fragment set:html={fallback ?? ''} />}
  </article>
</DataRoomLayout>
