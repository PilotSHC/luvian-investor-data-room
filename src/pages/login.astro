---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LuvianMark from '@/components/LuvianMark.astro';

const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');
const next = url.searchParams.get('next') ?? '/';
---

<BaseLayout title="Sign In · Luvian Data Room" showChrome={false}>
  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="mb-8 flex items-center gap-3">
        <LuvianMark size="md" />
        <div>
          <h1 class="text-lg font-semibold text-ink-900">Luvian Labs LLC</h1>
          <p class="text-xs text-ink-500">Investor data room · Pre-seed · 2026</p>
        </div>
      </div>

      <div class="card">
        <h2 class="mb-1 text-xl font-semibold text-ink-900">Restricted Access</h2>
        <p class="mb-6 text-sm text-ink-700">
          This data room is shared with prospective investors only. Enter the
          access code provided by Stephan Claxton. After signing in you'll be
          asked to acknowledge a short confidentiality and privacy notice
          before the materials are shown.
        </p>

        {error && (
          <div class="mb-4 rounded-md bg-red-50 p-3 text-sm text-red-700 ring-1 ring-red-200">
            That access code didn't match. Try again, or email
            <a class="underline" href="mailto:stephan@luvian.info">stephan@luvian.info</a>.
          </div>
        )}

        <form method="POST" action="/api/auth" class="space-y-4">
          <input type="hidden" name="next" value={next} />
          <div>
            <label for="password" class="block text-xs font-medium uppercase tracking-wide text-ink-500">
              Access code
            </label>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="off"
              autofocus
              required
              minlength="4"
              class="mt-1 block w-full rounded-md border-0 bg-white px-3 py-2 text-ink-900 ring-1 ring-inset ring-ink-300 placeholder:text-ink-400 focus:ring-2 focus:ring-inset focus:ring-accent"
              placeholder="••••••••••"
            />
          </div>
          <button type="submit" class="btn-primary w-full">Unlock data room</button>
        </form>

        <p class="mt-6 text-xs text-ink-500">
          By submitting the access code you confirm that you will keep these
          materials confidential and use them solely for evaluating a potential
          investment in Luvian Labs LLC. See our
          <a class="text-accent-dark underline" href="/privacy">privacy notice</a>.
        </p>
      </div>

      <div class="mt-6 text-center text-xs text-ink-500">
        © {new Date().getFullYear()} Luvian Labs LLC ·
        <a class="text-accent-dark underline" href="/privacy">Privacy</a>
        · stephan@luvian.info
      </div>
    </div>
  </main>
</BaseLayout>
