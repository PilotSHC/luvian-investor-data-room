---
import { visibleFiles, visibleSections } from '@/data/sections';

interface Props {
  currentSection?: string;
  currentSlug?: string;
}

const { currentSection, currentSlug } = Astro.props;
const tier = Astro.locals.investorTier ?? 1;
const sectionsForTier = visibleSections(tier);
---

<nav class="text-sm" data-sidebar-nav>
  <a
    href="/"
    class={`block rounded-md px-3 py-2 ring-1 ring-ink-200 transition hover:bg-ink-50 ${
      !currentSection ? 'bg-accent/10 text-accent-dark ring-accent/30' : 'bg-white text-ink-800'
    }`}
  >
    <div class="text-xs uppercase tracking-wide text-ink-500">Home</div>
    <div class="mt-1 font-medium">Data Room Index</div>
  </a>

  <details
    class="mt-4 rounded-md ring-1 ring-ink-200 bg-white lg:hidden"
    data-toc-root
  >
    <summary
      class="flex cursor-pointer select-none items-center justify-between px-3 py-2 text-sm font-medium text-ink-900 hover:bg-ink-50"
    >
      <span class="flex items-center gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.6"
          stroke="currentColor"
          class="h-4 w-4 text-ink-500"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
        </svg>
        Table of Contents
      </span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.8"
        stroke="currentColor"
        class="h-4 w-4 text-ink-400 transition-transform group-open:rotate-180"
        data-toc-chevron
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </summary>
    <div class="border-t border-ink-200 px-1 pb-2 pt-1">
      <ul class="space-y-1">
        {sectionsForTier.map((section) => {
          const isActive = currentSection === section.id;
          return (
            <li>
              <details
                class="group rounded-md"
                open={isActive}
                data-toc-section
              >
                <summary
                  class={`flex cursor-pointer select-none items-center justify-between rounded-md px-3 py-1.5 text-sm transition hover:bg-ink-50 ${
                    isActive ? 'bg-accent/5 text-accent-dark font-semibold' : 'text-ink-800'
                  }`}
                >
                  <span class="flex items-baseline gap-2">
                    <span class="font-mono text-xs text-ink-400">{section.number}</span>
                    <span>{section.title}</span>
                  </span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.8"
                    stroke="currentColor"
                    class="h-3.5 w-3.5 text-ink-400 transition-transform group-open:rotate-180"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </summary>
                <ul class="mt-1 space-y-0.5 pb-1">
                  <li>
                    <a
                      href={section.href}
                      class={`block rounded-md px-5 py-1 text-xs transition hover:bg-ink-50 hover:text-ink-900 ${
                        isActive && !currentSlug
                          ? 'text-accent-dark font-medium'
                          : 'text-ink-600'
                      }`}
                    >
                      Section overview
                    </a>
                  </li>
                  {visibleFiles(section, tier).map((file) => (
                    <li>
                      <a
                        href={`${section.href}/${file.slug}`}
                        class={`block rounded-md px-5 py-1 text-ink-700 transition hover:bg-ink-50 hover:text-ink-900 ${
                          isActive && currentSlug === file.slug
                            ? 'bg-accent/10 text-accent-dark ring-1 ring-accent/30'
                            : ''
                        }`}
                      >
                        {file.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          );
        })}
      </ul>
    </div>
  </details>

  <div class="mt-4 hidden space-y-3 lg:block">
    {sectionsForTier.map((section) => {
      const isActive = currentSection === section.id;
      return (
        <details class="group" open={isActive} data-toc-section>
          <summary
            class={`flex cursor-pointer select-none items-baseline justify-between gap-2 rounded-md px-3 py-1.5 transition hover:bg-ink-50 ${
              isActive ? 'bg-accent/5 text-accent-dark font-semibold' : 'text-ink-800'
            }`}
          >
            <span class="flex items-baseline gap-2">
              <span class="font-mono text-xs text-ink-400">{section.number}</span>
              <span>{section.title}</span>
            </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.8"
              stroke="currentColor"
              class="h-3.5 w-3.5 text-ink-400 transition-transform group-open:rotate-180"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </summary>
          <ul class="mt-1 space-y-0.5">
            <li>
              <a
                href={section.href}
                class={`block rounded-md px-5 py-1 text-xs transition hover:bg-ink-50 hover:text-ink-900 ${
                  isActive && !currentSlug
                    ? 'text-accent-dark font-medium'
                    : 'text-ink-600'
                }`}
              >
                Section overview
              </a>
            </li>
            {visibleFiles(section, tier).map((file) => (
              <li>
                <a
                  href={`${section.href}/${file.slug}`}
                  class={`block rounded-md px-5 py-1 text-ink-700 transition hover:bg-ink-50 hover:text-ink-900 ${
                    isActive && currentSlug === file.slug
                      ? 'bg-accent/10 text-accent-dark ring-1 ring-accent/30'
                      : ''
                  }`}
                >
                  {file.title}
                </a>
              </li>
            ))}
          </ul>
        </details>
      );
    })}
  </div>
</nav>
